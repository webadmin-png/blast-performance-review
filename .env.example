# ===================================================================
# .env.example — copy to .env and fill in the values.
#   cp .env.example .env
# .env is git-ignored; never commit real secrets. Share them out-of-band.
# Values are read by config/settings.py.
# ===================================================================

# -------------------------------------------------------------------
# SHOPIFY  (REQUIRED to run main.py)
# SHOPIFY_ACCESS_TOKEN is auto-fetched/refreshed by auth/token_manager.py
# from CLIENT_ID + CLIENT_SECRET and written back to this file — you can
# leave it blank on first run.
# -------------------------------------------------------------------
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2026-01

# -------------------------------------------------------------------
# ATTENTIVE  (REQUIRED — used in report transforms)
# Custom-app Bearer token: https://ui.attentivemobile.com/integrations/custom-app/management
# -------------------------------------------------------------------
ATTENTIVE_API_KEY=
ATTENTIVE_BASE_URL=https://api.attentivemobile.com/v1

# -------------------------------------------------------------------
# GOOGLE SHEETS  (OPTIONAL — current main.py does not call Sheets)
# Place the service-account JSON at ./credentials/service_account.json.
# In Docker, keep CREDS_PATH pointed at the container path below.
# -------------------------------------------------------------------
CREDS_PATH=/app/credentials/service_account.json
ORDER_SHEET_ID=
ORDER_SHEET_NAME=Sheet1
RETURN_SHEET_ID=
RETURN_SHEET_NAME=Sheet1
SUMMARY_SHEET_ID=
MASTER_DATA_SHEET_NAME=Sheet1
SUMMARY_SHEET_NAME=SUMMARY
STOCK_BALI_SHEET_ID=
STOCK_BALI_SHEET_NAME=Master Sheets

# -------------------------------------------------------------------
# REDO returns API  (OPTIONAL)
# -------------------------------------------------------------------
BAREER_TOKEN=
STORE_ID=

# -------------------------------------------------------------------
# SALESFORCE  (OPTIONAL)
# -------------------------------------------------------------------
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# -------------------------------------------------------------------
# HUGGING FACE Inference API  (OPTIONAL)
# -------------------------------------------------------------------
HF_TOKEN=
